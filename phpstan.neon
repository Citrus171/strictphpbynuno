includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - phar://phpstan.phar/conf/bleedingEdge.neon

parameters:

    paths:
        - app
        - bootstrap/app.php
        - config
        - database
        - public
        - routes


    level: max

    tmpDir: /tmp/phpstan

    stubFiles:
        - stubs/Lunar/Models/Cart.php
        - stubs/Lunar/Models/Order.php
        - stubs/Lunar/Models/OrderLine.php
